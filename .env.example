# ── Application ──────────────────────────────────────────────
# Port where the NestJS API will listen
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────
# Connection settings for PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bus_monitor
DB_USER=postgres
DB_PASSWORD=postgres

# ── Kafka (optional — killswitch for local dev) ──────────────
# Set to "true" to enable Kafka microservice transport.
# When false, the API runs HTTP-only and simulation endpoints
# return a deterministic "disabled" response.
KAFKA_ENABLED=false
# Comma-separated list of Kafka broker addresses.
KAFKA_BROKERS=localhost:9092
# Kafka client identifier (optional — defaults to "bus-monitor")
KAFKA_CLIENT_ID=bus-monitor
# Kafka consumer group ID (optional — defaults to "bus-monitor-group")
KAFKA_GROUP_ID=bus-monitor-group
# Zookeeper port (used by docker-compose)
ZOOKEEPER_PORT=2181
# Kafka port exposed to host (used by docker-compose)
KAFKA_PORT=9092

KAFKAJS_NO_PARTITIONER_WARNING=1